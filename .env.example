# Copy this file to .env and fill in secrets. Never commit .env.

# PostgreSQL
POSTGRES_USER=hermes
POSTGRES_PASSWORD=change-me
POSTGRES_DB=hermes

# Hermes Agent model configuration
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/nemotron-3-ultra-550b-a55b
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=phi4-mini

# Discord native Hermes gateway
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USERS=875243736987217920
DISCORD_REQUIRE_MENTION=true
DISCORD_COMMAND_SYNC_POLICY=bulk

# Optional provider credentials (not used unless configured in Hermes)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
HF_TOKEN=

# Watchtower
WATCHTOWER_POLL_INTERVAL=86400
