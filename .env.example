# ============================================================
# Portable AI Server — environment configuration
# Copy to `.env` and fill in real values. Never commit `.env`.
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=hermes
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=hermes

# --- Hermes Agent ---
HERMES_PORT=8080
HERMES_LOG_LEVEL=info
# Add any Hermes-specific API keys / settings here:
# HERMES_API_KEY=

# --- Ollama ---
# Default model pulled by scripts/pull-models.sh
OLLAMA_DEFAULT_MODEL=llama3.1:8b

# --- Watchtower ---
# Seconds between update checks (86400 = daily)
WATCHTOWER_POLL_INTERVAL=86400

# --- Nginx / TLS ---
# Public hostname of this server (used by nginx and certbot later)
SERVER_NAME=ai.example.com
